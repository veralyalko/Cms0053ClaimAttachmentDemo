        <section>
          <templateId root="2.16.840.1.113883.10.20.22.2.13"/>
          <code code="10154-3" codeSystem="2.16.840.1.113883.6.1" displayName="Chief Complaint"/>
          <title>Chief Complaint</title>
          <text>
            <paragraph>Patient presents with chronic lower back pain radiating to the left leg, worsening over the past 3 months. Pain rated 7/10 at rest, 9/10 with activity.</paragraph>
          </text>
        </section>
      </component>
      <component>
        <!-- Assessment and Plan: 51847-2 -->
        <section>
          <templateId root="2.16.840.1.113883.10.20.22.2.9" extension="2014-06-09"/>
          <code code="51847-2" codeSystem="2.16.840.1.113883.6.1" displayName="Assessment and Plan"/>
          <title>Assessment and Plan</title>
          <text>
            <paragraph>Assessment: Lumbar spinal stenosis at L4-L5 (M48.06). MRI confirms moderate stenosis with left-sided foraminal narrowing.</paragraph>
            <paragraph>Plan: 1) Continue conservative management with PT and NSAIDs. 2) Epidural steroid injection at L4-L5 scheduled. 3) Surgical consult if no improvement in 6 weeks. 4) Follow up in 4 weeks.</paragraph>
          </text>
        </section>
      </component>
    </structuredBody>
