      <!-- Chief Complaint LOINC 10154-3 -->
      <component>
        <section>
          <code code="10154-3" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Chief complaint Narrative - Reported" />
          <title>Chief Complaint</title>
          <text>
            <paragraph>
              Patient presents with increased shortness of breath, wheezing, and nocturnal cough
              over the past 2 weeks. Reports decreased response to rescue inhaler (albuterol).
            </paragraph>
          </text>
        </section>
      </component>

      <!-- History of Present Illness LOINC 10164-2 -->
      <component>
        <section>
          <templateId root="2.16.840.1.113883.10.20.22.2.20" extension="2015-08-01" />
          <code code="10164-2" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="History of present illness Narrative" />
          <title>History of Present Illness</title>
          <text>
            <paragraph>
              Maria Garcia is a 43-year-old female with known history of moderate persistent
              asthma (J45.909) diagnosed in 2015. She is currently managed on fluticasone/salmeterol
              250/50 mcg BID and albuterol PRN. She reports that over the past 2 weeks she has needed
              her rescue inhaler daily, up from usual use of once weekly. Triggers include cold air
              and recent upper respiratory infection approximately 3 weeks prior. No ER visits since
              last year. No oral corticosteroid courses in the past 6 months.
            </paragraph>
            <paragraph>
              <content styleCode="Bold">Review of Systems:</content>
              Positive for dyspnea on exertion, nocturnal cough, chest tightness.
              Negative for fever, chills, purulent sputum, hemoptysis.
              No recent travel. No new environmental exposures reported.
            </paragraph>
          </text>
        </section>
      </component>

      <!-- Physical Exam LOINC 29545-1 -->
      <component>
        <section>
          <templateId root="2.16.840.1.113883.10.20.2.10" extension="2015-08-01" />
          <code code="29545-1" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Physical findings Narrative" />
          <title>Physical Examination</title>
          <text>
            <paragraph><content styleCode="Bold">Vital Signs:</content></paragraph>
            <list>
              <item>BP: 122/78 mmHg</item>
              <item>HR: 88 bpm, regular</item>
              <item>RR: 18/min</item>
              <item>Temp: 98.6°F (37.0°C)</item>
              <item>SpO2: 96% on room air</item>
              <item>Weight: 142 lbs | Height: 5'4" | BMI: 24.4</item>
            </list>
            <paragraph><content styleCode="Bold">Respiratory:</content>
              Mild expiratory wheezing bilaterally, more prominent at lung bases.
              No accessory muscle use. Air entry adequate bilaterally.
              Prolonged expiratory phase noted.
            </paragraph>
            <paragraph><content styleCode="Bold">Cardiovascular:</content>
              Regular rate and rhythm. No murmurs.
            </paragraph>
            <paragraph><content styleCode="Bold">General:</content>
              Alert, oriented, mild respiratory distress. Able to speak in full sentences.
            </paragraph>
          </text>
        </section>
      </component>

      <!-- Assessment and Plan LOINC 51847-2 -->
      <component>
        <section>
          <templateId root="2.16.840.1.113883.10.20.22.2.9" extension="2014-06-09" />
          <code code="51847-2" codeSystem="2.16.840.1.113883.6.1" codeSystemName="LOINC" displayName="Evaluation + Plan note" />
          <title>Assessment and Plan</title>
          <text>
            <paragraph>
              <content styleCode="Bold">Assessment:</content>
              Moderate persistent asthma (J45.909) with acute exacerbation triggered by recent
              URI. Step-up therapy warranted given current symptom burden.
            </paragraph>
            <paragraph>
              <content styleCode="Bold">Plan:</content>
            </paragraph>
            <list>
              <item>Step-up to fluticasone/salmeterol 500/50 mcg BID.</item>
              <item>Short course oral prednisone 40 mg daily x 5 days.</item>
              <item>Continue albuterol MDI PRN; patient educated on proper inhaler technique.</item>
              <item>Spirometry ordered — results pending.</item>
              <item>Patient educated on asthma action plan (written copy provided in Spanish).</item>
              <item>Follow-up in 2–4 weeks to reassess. Sooner if worsening.</item>
              <item>ER precautions discussed.</item>
            </list>
          </text>
