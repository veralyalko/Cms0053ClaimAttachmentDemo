@page
@model Cms0053ClaimAttachmentDemo.Pages.Provider.DirectSubmitModel
@{
    ViewData["Title"] = "Direct Submission to Payer";
}

<div class="mb-4">
    <h1 class="h2 fw-bold">Direct Submission to Payer</h1>
    <p class="text-muted mb-0">Workflow 3 &mdash; Unsolicited direct submission from provider or EMR system.</p>
</div>

<div class="alert alert-info small mb-4">
    <strong>[X12-275-PLACEHOLDER]</strong> In production, a provider's EMR or billing system would
    transmit an X12 275 transaction directly to the payer. In this demo, you can either select a
    seeded EMR document or upload your own file — both enter the same shared processing pipeline.
</div>

<ul class="nav nav-tabs mb-4" id="submitTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="emr-tab" data-bs-toggle="tab"
                data-bs-target="#emr-pane" type="button" role="tab">
            Select EMR Document
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="upload-tab" data-bs-toggle="tab"
                data-bs-target="#upload-pane" type="button" role="tab">
            Upload Your Own File
        </button>
    </li>
</ul>

<div class="tab-content" id="submitTabsContent">

    @* Tab 1: Select EMR Document *@
    <div class="tab-pane fade show active" id="emr-pane" role="tabpanel">
        <div class="row">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-header fw-semibold">Select a Document from EMR</div>
                    <div class="card-body">
                        <form method="post" asp-page-handler="Emr">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold">Available EMR Documents <span class="text-danger">*</span></label>
                                @if (!Model.EmrDocuments.Any())
                                {
                                    <div class="alert alert-warning small">No EMR documents available.</div>
                                }
                                else
                                {
                                    <div class="list-group">
                                        @foreach (var doc in Model.EmrDocuments)
                                        {
                                            <label class="list-group-item list-group-item-action">
                                                <input type="radio" name="EmrInput.EmrDocumentId"
                                                       value="@doc.Id" class="form-check-input me-2"
                                                       @(Model.EmrInput.EmrDocumentId == doc.Id ? "checked" : "") />
                                                <span class="fw-semibold">@doc.DocumentName</span>
                                                <br />
                                                <span class="text-muted small">
                                                    @doc.DocumentType &mdash; NPI: <span class="font-monospace">@doc.ProviderNPI</span>
                                                    &mdash; Patient: @doc.PatientName
                                                    &mdash; Service: @doc.ServiceDate.ToString("MM/dd/yyyy")
                                                </span>
                                            </label>
                                        }
                                    </div>
                                    <span asp-validation-for="EmrInput.EmrDocumentId" class="text-danger small"></span>
                                }
                            </div>

                            <div class="mb-3">
                                <label asp-for="EmrInput.SubmitterName" class="form-label fw-semibold">Your Name / System Name</label>
                                <input asp-for="EmrInput.SubmitterName" class="form-control" placeholder="e.g. Epic EMR, Dr. Johnson" />
                            </div>

                            <div class="mb-4">
                                <label asp-for="EmrInput.Notes" class="form-label fw-semibold">Notes (optional)</label>
                                <textarea asp-for="EmrInput.Notes" class="form-control" rows="2"
                                          placeholder="Any additional context..."></textarea>
                            </div>

                            <button type="submit" class="btn btn-primary">Submit to Payer</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-5 mt-4 mt-lg-0">
                <div class="card border-secondary">
                    <div class="card-header bg-light fw-semibold">How this works</div>
                    <div class="card-body small">
                        <ol class="ps-3 mb-0">
                            <li class="mb-1">Select a pre-loaded EMR document (already on disk).</li>
                            <li class="mb-1">Submit — the file is copied into the payer's upload store.</li>
                            <li class="mb-1">The shared pipeline validates, then matches to a seeded claim.</li>
                            <li>You are redirected to the attachment detail to see the result.</li>
                        </ol>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Tab 2: Upload Your Own File *@
    <div class="tab-pane fade" id="upload-pane" role="tabpanel">
        <div class="row">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-header fw-semibold">Upload File Directly</div>
                    <div class="card-body">
                        <form method="post" enctype="multipart/form-data" asp-page-handler="Upload">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

                            <div class="row g-3 mb-3">
                                <div class="col-sm-6">
                                    <label asp-for="UploadInput.ProviderNPI" class="form-label fw-semibold">Provider NPI <span class="text-danger">*</span></label>
                                    <input asp-for="UploadInput.ProviderNPI" class="form-control font-monospace"
                                           placeholder="10-digit NPI" maxlength="10" />
                                    <span asp-validation-for="UploadInput.ProviderNPI" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label asp-for="UploadInput.DocumentType" class="form-label fw-semibold">Document Type <span class="text-danger">*</span></label>
                                    <select asp-for="UploadInput.DocumentType" class="form-select">
                                        <option value="">-- Select --</option>
                                        @foreach (var dt in DirectSubmitModel.DocumentTypes)
                                        {
                                            <option value="@dt">@dt</option>
                                        }
                                    </select>
                                    <span asp-validation-for="UploadInput.DocumentType" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="col-sm-6">
                                    <label asp-for="UploadInput.PatientName" class="form-label fw-semibold">Patient Name <span class="text-danger">*</span></label>
                                    <input asp-for="UploadInput.PatientName" class="form-control" placeholder="Full name" />
                                    <span asp-validation-for="UploadInput.PatientName" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label asp-for="UploadInput.PatientDOB" class="form-label fw-semibold">Patient DOB</label>
                                    <input asp-for="UploadInput.PatientDOB" type="date" class="form-control" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="UploadInput.ServiceDate" class="form-label fw-semibold">Service Date <span class="text-danger">*</span></label>
                                <input asp-for="UploadInput.ServiceDate" type="date" class="form-control" style="width:200px" />
                                <span asp-validation-for="UploadInput.ServiceDate" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="UploadInput.File" class="form-label fw-semibold">Document File <span class="text-danger">*</span></label>
                                <input asp-for="UploadInput.File" type="file" class="form-control"
                                       accept=".pdf,.jpg,.jpeg,.png,.tiff,.tif,.txt,.xml" />
                                <div class="form-text">Accepted: C-CDA XML, PDF, JPEG, PNG, TIFF, plain text. Max 10 MB.</div>
                                <span asp-validation-for="UploadInput.File" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="UploadInput.SubmitterName" class="form-label fw-semibold">Your Name / System Name</label>
                                <input asp-for="UploadInput.SubmitterName" class="form-control" placeholder="e.g. Provider Portal, Dr. Lee" />
                            </div>

                            <div class="mb-4">
                                <label asp-for="UploadInput.Notes" class="form-label fw-semibold">Notes (optional)</label>
                                <textarea asp-for="UploadInput.Notes" class="form-control" rows="2"
                                          placeholder="Any additional context..."></textarea>
                            </div>

                            <div class="mb-3 p-3 bg-light rounded border small">
                                <strong>Seeded claims for matching:</strong>
                                <table class="table table-sm table-borderless mb-0 mt-2 small">
                                    <thead><tr><th>NPI</th><th>Patient</th><th>Service Date</th></tr></thead>
                                    <tbody>
                                        <tr><td class="font-monospace">1234567890</td><td>John Smith</td><td>10/15/2025</td></tr>
                                        <tr><td class="font-monospace">1234567890</td><td>Maria Garcia</td><td>11/03/2025</td></tr>
                                        <tr><td class="font-monospace">1234567890</td><td>Sarah Thompson</td><td>10/22/2025</td></tr>
                                        <tr><td class="font-monospace">1234567890</td><td>Richard Torres</td><td>12/03/2025</td></tr>
                                        <tr><td class="font-monospace">9876543210</td><td>Robert Johnson</td><td>09/28/2025</td></tr>
                                        <tr><td class="font-monospace">9876543210</td><td>Linda Chen</td><td>12/10/2025</td></tr>
                                        <tr><td class="font-monospace">9876543210</td><td>David Kim</td><td>11/07/2025</td></tr>
                                        <tr><td class="font-monospace">5551234567</td><td>James Wilson</td><td>11/20/2025</td></tr>
                                        <tr><td class="font-monospace">5551234567</td><td>Patricia Moore</td><td>12/05/2025</td></tr>
                                        <tr><td class="font-monospace">5551234567</td><td>Amanda Foster</td><td>11/25/2025</td></tr>
                                    </tbody>
                                </table>
                            </div>

                            <button type="submit" class="btn btn-primary">Submit to Payer</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Restore correct tab after validation failure (form posts to a handler, so re-open its tab)
        document.querySelectorAll('form[asp-page-handler]').forEach(function (form) {
            form.addEventListener('submit', function () {
                var handler = form.getAttribute('action') || '';
                var tab = handler.includes('Upload') ? 'upload-tab' : 'emr-tab';
                sessionStorage.setItem('directSubmitTab', tab);
            });
        });
        var savedTab = sessionStorage.getItem('directSubmitTab');
        if (savedTab) {
            sessionStorage.removeItem('directSubmitTab');
            var tabEl = document.getElementById(savedTab);
            if (tabEl) new bootstrap.Tab(tabEl).show();
        }
    </script>
}
