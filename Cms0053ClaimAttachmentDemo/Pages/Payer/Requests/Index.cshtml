@page
@model Cms0053ClaimAttachmentDemo.Pages.Payer.Requests.IndexModel
@{
    ViewData["Title"] = "Attachment Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 fw-bold">Attachment Requests</h1>
        <p class="text-muted mb-0">Workflow 1 &mdash; Solicited attachments. Payer-initiated requests for provider documentation.</p>
    </div>
    <a asp-page="/Payer/Requests/Create" class="btn btn-primary">+ New Request</a>
</div>

@if (!Model.Requests.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <p class="mb-3">No attachment requests yet.</p>
            <a asp-page="/Payer/Requests/Create" class="btn btn-primary">Create the first request</a>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tracking #</th>
                        <th>Claim</th>
                        <th>Patient</th>
                        <th>Document Requested</th>
                        <th>Requested</th>
                        <th>Due By</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in Model.Requests)
                    {
                        <tr>
                            <td class="font-monospace small">@req.TrackingNumber</td>
                            <td>@req.Claim.ClaimNumber</td>
                            <td>@req.Claim.PatientName</td>
                            <td>@req.DocumentTypeRequested</td>
                            <td class="small">@req.RequestedAt.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td class="small">@req.DueDate.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td>
                                @{
                                    var badgeClass = req.Status switch
                                    {
                                        "Pending"   => "bg-warning text-dark",
                                        "Fulfilled" => "bg-success",
                                        "Expired"   => "bg-secondary",
                                        "Cancelled" => "bg-danger",
                                        _           => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@req.Status</span>
                            </td>
                            <td>
                                <a asp-page="/Payer/Requests/Detail" asp-route-id="@req.Id"
                                   class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
