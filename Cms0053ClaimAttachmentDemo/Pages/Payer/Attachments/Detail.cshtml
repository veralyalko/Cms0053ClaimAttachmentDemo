@page "{id:int}"
@model Cms0053ClaimAttachmentDemo.Pages.Payer.Attachments.DetailModel
@using Cms0053ClaimAttachmentDemo.Models
@{
    ViewData["Title"] = "Attachment #" + Model.Attachment.Id;
    var a = Model.Attachment;

    var statusBadge = a.Status switch
    {
        AttachmentStatus.Accepted         => "bg-success",
        AttachmentStatus.ValidationFailed => "bg-danger",
        AttachmentStatus.MatchFailed      => "bg-warning text-dark",
        AttachmentStatus.Matched          => "bg-primary",
        AttachmentStatus.Validated        => "bg-info text-dark",
        _                                 => "bg-secondary"
    };

    var sourceLabel = a.SourceType switch
    {
        AttachmentSourceType.Solicited               => "Workflow 1 — Solicited",
        AttachmentSourceType.UnsolicitedClearinghouse => "Workflow 2 — Unsolicited via Clearinghouse",
        AttachmentSourceType.UnsolicitedDirect        => "Workflow 3 — Unsolicited Direct / EMR",
        _                                             => a.SourceType
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 fw-bold">Attachment #@a.Id</h1>
        <p class="text-muted mb-0">@sourceLabel</p>
    </div>
    <span class="badge @statusBadge fs-6">@a.Status</span>
</div>

<div class="row g-4">

    <div class="col-lg-8">

        <div class="card mb-4">
            <div class="card-header fw-semibold">
                Validation Result
                @if (a.ValidationResult is not null)
                {
                    if (a.ValidationResult.IsValid)
                    {
                        <span class="badge bg-success ms-2">Passed</span>
                    }
                    else
                    {
                        <span class="badge bg-danger ms-2">Failed</span>
                    }
                }
            </div>
            <div class="card-body">
                @if (a.ValidationResult is null)
                {
                    <p class="text-muted mb-0">Validation not yet run.</p>
                }
                else if (a.ValidationResult.IsValid && !Model.ValidationWarnings.Any())
                {
                    <p class="text-success mb-0">
                        <strong>All checks passed.</strong> File and metadata are valid.
                    </p>
                }
                else
                {
                    @if (Model.ValidationErrors.Any())
                    {
                        <p class="fw-semibold text-danger mb-1">Errors:</p>
                        <ul class="text-danger mb-3">
                            @foreach (var err in Model.ValidationErrors)
                            {
                                <li>@err</li>
                            }
                        </ul>
                    }
                    @if (Model.ValidationWarnings.Any())
                    {
                        <p class="fw-semibold text-warning mb-1">Warnings:</p>
                        <ul class="text-warning">
                            @foreach (var w in Model.ValidationWarnings)
                            {
                                <li>@w</li>
                            }
                        </ul>
                    }
                    @if (a.ValidationResult.IsValid)
                    {
                        <p class="text-success mb-0"><strong>No errors.</strong> Warnings are informational only.</p>
                    }
                }
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header fw-semibold">
                Claim Match
                @if (a.Claim is not null)
                {
                    <span class="badge bg-success ms-2">Matched</span>
                }
                else if (a.Status == AttachmentStatus.MatchFailed)
                {
                    <span class="badge bg-warning text-dark ms-2">Not Found</span>
                }
            </div>
            <div class="card-body">
                @if (a.Claim is not null)
                {
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Claim Number</dt>
                        <dd class="col-sm-8 fw-semibold">@a.Claim.ClaimNumber</dd>
                        <dt class="col-sm-4">Patient</dt>
                        <dd class="col-sm-8">@a.Claim.PatientName</dd>
                        <dt class="col-sm-4">Provider</dt>
                        <dd class="col-sm-8">@a.Claim.ProviderName</dd>
                        <dt class="col-sm-4">Provider NPI</dt>
                        <dd class="col-sm-8 font-monospace">@a.Claim.ProviderNPI</dd>
                        <dt class="col-sm-4">Service Date</dt>
                        <dd class="col-sm-8">@a.Claim.ServiceDate.ToString("MM/dd/yyyy")</dd>
                        <dt class="col-sm-4">Diagnosis</dt>
                        <dd class="col-sm-8">@a.Claim.DiagnosisCode</dd>
                        <dt class="col-sm-4">Claim Status</dt>
                        <dd class="col-sm-8">@a.Claim.Status</dd>
                    </dl>
                }
                else
                {
                    <p class="text-warning mb-1">
                        <strong>No matching claim found.</strong>
                    </p>
                    <p class="text-muted small mb-0">
                        The payer system searched for a claim with NPI
                        <span class="font-monospace">@a.ProviderNPI</span>,
                        patient name <strong>@a.PatientName</strong>,
                        and service date <strong>@a.ServiceDate.ToString("MM/dd/yyyy")</strong> (±7 days).
                        No match was found. Manual review required.
                    </p>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header fw-semibold">Status History</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Date / Time (UTC)</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Notes</th>
                            <th>By</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in a.StatusHistory)
                        {
                            <tr>
                                <td class="small font-monospace">@h.ChangedAt.ToString("MM/dd/yyyy HH:mm:ss")</td>
                                <td><span class="text-muted small">@(h.FromStatus ?? "—")</span></td>
                                <td><strong>@h.ToStatus</strong></td>
                                <td class="small">@h.Notes</td>
                                <td class="small text-muted">@h.ChangedBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <div class="col-lg-4">

        <div class="card mb-4">
            <div class="card-header fw-semibold">File Information</div>
            <div class="card-body">
                <dl class="mb-0">
                    <dt>Original Filename</dt>
                    <dd class="text-break">@a.FileName</dd>
                    <dt>File Size</dt>
                    <dd>@($"{a.FileSizeBytes:N0}") bytes</dd>
                    <dt>Content Type</dt>
                    <dd>@a.ContentType</dd>
                    <dt>Document Type</dt>
                    <dd>@a.DocumentType</dd>
                    <dt class="mt-2">SHA-256 Hash</dt>
                    <dd class="font-monospace small text-break">@a.FileHash</dd>
                </dl>
                <div class="mt-3 d-grid gap-2">
                    <a href="/uploads/@a.StoredFileName" target="_blank"
                       class="btn btn-outline-primary btn-sm">
                        View File
                    </a>
                    <a href="/uploads/@a.StoredFileName" download="@a.FileName"
                       class="btn btn-outline-secondary btn-sm">
                        Download File
                    </a>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header fw-semibold">Submission Details</div>
            <div class="card-body">
                <dl class="mb-0">
                    <dt>Source</dt>
                    <dd>@sourceLabel</dd>
                    <dt>Submitted By</dt>
                    <dd>@a.SubmittedBy</dd>
                    <dt>Submitted At</dt>
                    <dd class="small">@a.SubmittedAt.ToString("MM/dd/yyyy HH:mm:ss") UTC</dd>
                    <dt>Patient Name</dt>
                    <dd>@a.PatientName</dd>
                    <dt>Provider NPI</dt>
                    <dd class="font-monospace">@a.ProviderNPI</dd>
                    <dt>Service Date</dt>
                    <dd>@a.ServiceDate.ToString("MM/dd/yyyy")</dd>
                    @if (!string.IsNullOrWhiteSpace(a.Notes))
                    {
                        <dt>Notes</dt>
                        <dd>@a.Notes</dd>
                    }
                </dl>
            </div>
        </div>

        @if (a.AttachmentRequest is not null)
        {
            <div class="card">
                <div class="card-header fw-semibold">Attachment Request</div>
                <div class="card-body">
                    <dl class="mb-0">
                        <dt>Tracking Number</dt>
                        <dd class="font-monospace small">@a.AttachmentRequest.TrackingNumber</dd>
                        <dt>Status</dt>
                        <dd><span class="badge bg-success">@a.AttachmentRequest.Status</span></dd>
                    </dl>
                    <a asp-page="/Payer/Requests/Detail" asp-route-id="@a.AttachmentRequest.Id"
                       class="btn btn-sm btn-outline-secondary mt-2">View Request</a>
                </div>
            </div>
        }

    </div>
</div>
