@{
    ViewData["Title"] = "Demo Scenarios";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h2 fw-bold">Demo Scenarios</h1>
        <p class="text-muted mb-0">Step-by-step scripts for each CMS-0053-F workflow — success and failure paths.</p>
    </div>
</div>

<div class="alert alert-info mb-4">
    <strong>Fresh deploy?</strong>
    Go to <a href="/Payer/Dashboard" class="alert-link">Payer &rarr; Dashboard</a> and click
